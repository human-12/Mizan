{
  "entities": {
    "FatwaEntry": {
      "title": "FatwaEntry",
      "description": "A Shariah analysis report for a crypto asset.",
      "type": "object",
      "properties": {
        "asset": {
          "type": "string",
          "description": "The name or contract address of the asset."
        },
        "ruling": {
          "type": "string",
          "description": "The final approved ruling (Halal, Haram, Doubtful)."
        },
        "rulingStrength": {
          "type": "string",
          "description": "Qaṭ‘ī, Ẓann Ghālib, Ijtihādī, or Weak."
        },
        "rulingScore": {
          "type": "number",
          "description": "Internal score from 0 to 100."
        },
        "illahIdentified": {
          "type": "string",
          "description": "The effective cause identified."
        },
        "tahqiqAlManat": {
          "type": "string",
          "description": "Reality check on the protocol."
        },
        "dalilNarrative": {
          "type": "string",
          "description": "A fatwa-style proof narrative."
        },
        "dalilStack": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": { "type": "string" },
              "grade": { "type": "string" },
              "weight": { "type": "number" },
              "description": { "type": "string" }
            }
          },
          "description": "The stack of evidence used."
        },
        "aaoifi_evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "standard_id": { "type": "string" },
              "topic": { "type": "string" },
              "weight": { "type": "number" },
              "finding": { "type": "string" },
              "dalil_score_contribution": { "type": "number" },
              "relevance_notes": { "type": "string" }
            }
          }
        },
        "contraryView": {
          "type": "string",
          "description": "Contrary dalil considered and why it was rejected."
        },
        "riskMetrics": {
          "type": "object",
          "properties": {
            "non_permissible_revenue_pct": { "type": "number" },
            "riba_exposure_score": { "type": "number" },
            "gharar_exposure_score": { "type": "number" },
            "maysir_exposure_score": { "type": "number" },
            "centralization_risk_score": { "type": "number" }
          }
        },
        "areasNeedingReview": {
          "type": "array",
          "items": { "type": "string" }
        },
        "knowledge_graph": {
          "type": "object",
          "properties": {
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "node_id": { "type": "string" },
                  "type": { "type": "string" },
                  "source": { "type": "string" },
                  "confidence": { "type": "number" },
                  "explicitness": { "type": "number" },
                  "notes": { "type": "string" }
                }
              }
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "from_node_id": { "type": "string" },
                  "to_node_id": { "type": "string" },
                  "relation_type": { "type": "string" },
                  "confidence": { "type": "number" },
                  "explanation": { "type": "string" }
                }
              }
            }
          }
        },
        "xai_explanations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "date_approved": {
          "type": "string",
          "format": "date-time",
          "description": "The date the fatwa was approved."
        },
        "scholar_notes": {
          "type": "string",
          "description": "Additional notes from the scholar."
        },
        "scholarId": {
          "type": "string",
          "description": "The UID of the scholar who approved the fatwa."
        }
      },
      "required": ["asset", "ruling", "date_approved", "scholarId"]
    }
  },
  "firestore": {
    "/fatwas/{fatwaId}": {
      "schema": "FatwaEntry",
      "description": "Stores approved fatwa entries."
    }
  }
}
